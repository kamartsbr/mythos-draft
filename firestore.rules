rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers globais ─────────────────────────────────────────────────────
    
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Verifica se o usuário autenticado tem role == 'admin' no Firestore.
     * Agora que request.auth.uid == discord_id, esta função é confiável.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/forja_players/$(request.auth.uid))
         && get(/databases/$(database)/documents/forja_players/$(request.auth.uid)).data.role == 'admin')
      );
    }

    /**
     * Campos que apenas o Admin pode alterar num documento forja_players.
     */
    function onlyPlayerSelfServiceFields() {
      let allowed = ['profile_link', 'availability', 'catchphrase', 'nick', 'avatar_url', 'is_brazilian', 'aom_profile_id', 'aom_id'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // ─── /lobby_secrets ──────────────────────────────────────────────────────
    match /lobby_secrets/{lobbyId} {
      allow read, write: if isAdmin();
    }

    // ─── /lobbies ────────────────────────────────────────────────────────────
    match /lobbies/{lobbyId} {
      function isParticipantOrAdmin(res) {
        return isSignedIn() && (
          res.data.adminId == request.auth.uid ||
          res.data.captain1 == request.auth.uid ||
          res.data.captain2 == request.auth.uid ||
          isAdmin()
        );
      }

      function noAdminFieldsModified() {
        return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['adminId', 'isPermanent', 'discordWebhookUrl', 'discordMessageId']);
      }

      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.adminId == request.auth.uid;
      allow update: if isParticipantOrAdmin(resource)
                    && resource.data.status != 'finished'
                    && (isAdmin() || noAdminFieldsModified());
      allow delete: if isSignedIn() && (resource.data.adminId == request.auth.uid || isAdmin());

      match /messages/{messageId} {
        allow read: if true;
        allow create: if isSignedIn()
                      && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }

    // ─── /metadata ───────────────────────────────────────────────────────────
    match /metadata/{docId} {
      function isValidMetadata() {
        let data = request.resource.data;
        return data.keys().hasOnly(['activeLobbies', 'lastUpdated', 'lastUpdate', 'initialized'])
          && (data.get('activeLobbies', []) is list)
          && (data.get('activeLobbies', []).size() <= 200);
      }

      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /presets ────────────────────────────────────────────────────────────
    match /presets/{presetId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.createdBy == request.auth.uid);
    }

    // ─── /forja_players ──────────────────────────────────────────────────────
    match /forja_players/{playerId} {
      allow read: if true;

      // Criação: permite que o usuário crie seu próprio documento
      allow create: if isSignedIn()
                    && request.auth.uid == playerId
                    && !exists(/databases/$(database)/documents/forja_players/$(playerId))
                    && request.resource.data.get('role', 'player') == 'player'
                    && !('esports_elo_enabled' in request.resource.data)
                    && !('esports_elo_value' in request.resource.data)
                    && !('top_gods_admin' in request.resource.data)
                    && !('seed' in request.resource.data)
                    && !('is_reserve' in request.resource.data)
                    && !('status' in request.resource.data)
                    && !('team_id' in request.resource.data)
                    && !('created_at' in request.resource.data)
                    && !('updated_at' in request.resource.data)
                    && !('banned' in request.resource.data)
                    && !('admin_flags' in request.resource.data);

      // Update:
      allow update: if isSignedIn()
                    && (
                      isAdmin() || 
                      (
                        request.auth.uid == playerId &&
                        request.resource.data.get('role', 'player') == resource.data.get('role', 'player') &&
                        onlyPlayerSelfServiceFields()
                      )
                    );

      allow delete: if isAdmin();
    }

    // ─── /system (Time Sync) ─────────────────────────────────────────────────
    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /forja_teams ────────────────────────────────────────────────────────
    match /forja_teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /forja_content ──────────────────────────────────────────────────────
    match /forja_content/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /forja_schedule ─────────────────────────────────────────────────────
    match /forja_schedule/{entryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /forja_meta (draft session) ─────────────────────────────────────────
    match /forja_meta/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /forja_status ────────────────────────────────────────────────────────
    match /forja_status/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /forja_bans ────────────────────────────────────────────────────────
    match /forja_bans/{discordId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /bug_reports ────────────────────────────────────────────────────────
    // Bug reports are user-submitted diagnostics. Public users may create
    // bounded reports, but only admins can read or modify them.
    match /bug_reports/{reportId} {
      function isValidBugReport() {
        let data = request.resource.data;
        return data.keys().hasOnly(['lobbyId', 'description', 'timestamp', 'userAgent', 'status', 'url'])
          && data.lobbyId is string
          && data.lobbyId.size() <= 128
          && data.description is string
          && data.description.size() > 0
          && data.description.size() <= 2000
          && data.userAgent is string
          && data.userAgent.size() <= 512
          && data.status == 'new'
          && data.url is string
          && data.url.size() <= 1024
          && data.timestamp == request.time;
      }

      allow create: if isSignedIn() && isValidBugReport();
      allow read, update, delete: if isAdmin();
    }

    // ─── /test ───────────────────────────────────────────────────────────────
    match /test/connection {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
