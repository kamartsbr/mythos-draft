rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers globais ─────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Verifica se o usuário autenticado tem role == 'admin' no Firestore.
     * Nota: como a auth da Forja é Discord client-side (não Firebase Auth real),
     * request.auth.uid é o UID anônimo, não o discord_id. Esta função funciona
     * apenas quando o UID anônimo coincide com o document ID (não é o caso geral).
     * Operações críticas de admin usam Cloud Functions com admin SDK que bypassa rules.
     */
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/forja_players/$(request.auth.uid))
        && get(/databases/$(database)/documents/forja_players/$(request.auth.uid)).data.role == 'admin';
    }

    /**
     * Campos que apenas o Admin pode alterar num documento forja_players.
     * Retorna true se NENHUM campo proibido está sendo alterado pelo não-Admin.
     */
    function onlyPlayerSelfServiceFields() {
      let allowed = ['profile_link', 'availability', 'catchphrase'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // ─── /lobbies ────────────────────────────────────────────────────────────
    match /lobbies/{lobbyId} {
      function isParticipantOrAdmin(res) {
        return isSignedIn() && (
          res.data.adminId == request.auth.uid ||
          res.data.captain1 == request.auth.uid ||
          res.data.captain2 == request.auth.uid
        );
      }

      allow read: if true;
      allow create: if isSignedIn()
                    // SECURITY FIX: Impede Identity Spoofing — adminId deve ser o próprio UID
                    && request.resource.data.adminId == request.auth.uid;
      allow update: if isParticipantOrAdmin(resource)
                    && resource.data.status != 'finished';
      allow delete: if isSignedIn() && resource.data.adminId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if true;
        // SECURITY FIX: Impede Message Hijack — senderId deve ser o próprio UID
        allow create: if isSignedIn()
                      && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    // ─── /metadata ───────────────────────────────────────────────────────────
    // lobbyService.ts atualiza este documento client-side (refreshLobbyIndex).
    // Mantemos isSignedIn() para não quebrar, mas restringimos os campos permitidos
    // para evitar que um atacante injete dados arbitrários no índice de lobbies.
    match /metadata/{docId} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.resource.data.keys().hasOnly(
                     ['activeLobbies', 'lastUpdated', 'lastUpdate', 'initialized']
                   );
    }

    // ─── /presets ────────────────────────────────────────────────────────────
    match /presets/{presetId} {
      allow read: if true;
      // SECURITY FIX: Criação restrita a admin (evita que qualquer usuário crie presets)
      allow create: if isAdmin();
      allow update, delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // ─── /test ───────────────────────────────────────────────────────────────
    match /test/connection {
      allow read: if true;
    }

    // ─── /forja_players ──────────────────────────────────────────────────────
    match /forja_players/{playerId} {
      // Qualquer um pode ler a lista de jogadores (tabela pública)
      allow read: if true;

      // Criação: permite que qualquer usuário autenticado (anônimo) crie um novo 
      // jogador, DESDE QUE:
      //  1. Não sobrescreva um existente.
      //  2. Não injete role: 'admin' (SECURITY FIX principal).
      //  3. Não injete campos que só admin deveria definir.
      allow create: if isSignedIn()
                    && !exists(/databases/$(database)/documents/forja_players/$(playerId))
                    // SECURITY FIX: bloqueia injeção de role:admin
                    && request.resource.data.get('role', 'player') == 'player'
                    // SECURITY FIX: bloqueia campos admin-only na auto-inscrição
                    && !('esports_elo_enabled' in request.resource.data)
                    && !('esports_elo_value' in request.resource.data)
                    && !('top_gods_admin' in request.resource.data)
                    && !('seed' in request.resource.data)
                    && !('is_reserve' in request.resource.data);

      // Update:
      //   - Admin pode atualizar tudo (modal, role, esports_elo, top_gods_admin, is_reserve)
      //   - Self-service: jogador só pode alterar campos explicitamente permitidos
      allow update: if isAdmin()
                    || (isSignedIn()
                        && onlyPlayerSelfServiceFields());

      // Delete: apenas Admin pode remover inscrições, ou o próprio jogador
      allow delete: if isAdmin()
                    || (isSignedIn() && request.auth.uid == playerId);
    }

    // ─── /forja_teams ────────────────────────────────────────────────────────
    match /forja_teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /forja_content ──────────────────────────────────────────────────────
    match /forja_content/{contentId} {
      allow read: if true;
      // Regras, formato, premiação, torneio, settings: apenas Admin edita
      allow write: if isAdmin();
    }

    // ─── /forja_schedule ─────────────────────────────────────────────────────
    match /forja_schedule/{entryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /forja_meta (draft session) ─────────────────────────────────────────
    match /forja_meta/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /forja_status ────────────────────────────────────────────────────────
    match /forja_status/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /forja_bans ────────────────────────────────────────────────────────
    match /forja_bans/{discordId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}