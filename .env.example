# ============================================================
#  FORJA DE HEFESTO — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais.
#  O arquivo .env está no .gitignore — nunca comite segredos.
# ============================================================

# ─── Discord OAuth 2.0 ───────────────────────────────────────
# Client ID do seu App no Discord Developer Portal:
# https://discord.com/developers/applications → Seu App → General Information
# Após obter o ID, adicione o Redirect URI em:
# OAuth2 → Redirects → Adicionar: https://SEU-DOMINIO.com/forja
# (para dev local: http://localhost:5173/forja)
VITE_DISCORD_CLIENT_ID=SEU_CLIENT_ID_AQUI

# ─── Admins da Forja de Hefesto ──────────────────────────────
# IDs Discord (separados por vírgula) com acesso admin total.
# Omoradin (owner): 272372054526001152
VITE_FORJA_ADMIN_IDS=272372054526001152
